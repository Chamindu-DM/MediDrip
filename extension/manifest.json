{
  "manifest_version": 3,
  "name": "MediDrip - Clinical Fluid Tracker",
  "description": "Track patient fluid intake and output with smart reminders",
  "version": "1.0.0",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "alarms",
    "identity",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://api.asgardeo.io/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  }
}
